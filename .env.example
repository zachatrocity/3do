# Public URL used when this app is placed behind a reverse proxy.
APP_URL=http://localhost:8080

# HTTP listen port inside the container/process.
PORT=8080

# All durable runtime data lives here.
DATA_DIR=/data

# Runtime ownership for files created under DATA_DIR. Use your host UID/GID
# when you want backups and manual file inspection to line up with your user.
PUID=1000
PGID=1000

# SQLite database path. Defaults to ${DATA_DIR}/3do.db when unset.
DATABASE_PATH=/data/3do.db

# Max size for one request containing uploaded model files.
UPLOAD_MAX_MB=512

# Required for signed server-side sessions. Generate with:
# openssl rand -base64 32
SESSION_SECRET=
